{
  "name": "util",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/util/src",
  "projectType": "library",
  "tags": ["publishable"],
  "implicitDependencies": ["!util-test", "vitest"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/util"],
      "options": {
        "commands": [
          {
            "command": "npx nx run util:build-base"
          },
          {
            "command": "npx nx run util-test:build-base"
          },
          {
            "command": "npx nx run util-fetch:build-base"
          },
          {
            "command": "npx nx run util-oidc:build-base"
          },
          {
            "command": "npx nx run util-eslint:build-base"
          }
        ],
        "parallel": false
      }
    },
    "build-base": {
      "dependsOn": []
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "run-all-tests": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "description": "run util tests",
            "command": "npx nx test util"
          },
          {
            "description": "run util-test tests",
            "command": "npx nx test util-test"
          },
          {
            "description": "run util-fetch tests",
            "command": "npx nx test util-fetch"
          },
          {
            "description": "run util-oidc tests",
            "command": "npx nx test util-oidc"
          }
        ],
        "color": true,
        "parallel": false
      }
    },
    "ci-publish-npmjs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd ./dist/packages/util && npm publish --access public"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/util"
      }
    }
  }
}
