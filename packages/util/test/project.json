{
  "name": "util-test",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/util/test/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build-base": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/util/test",
        "tsConfig": "packages/util/test/tsconfig.lib.json",
        "packageJson": "packages/util/test/package.json",
        "main": "packages/util/test/src/index.ts",
        "generateExportsField": false,
        "assets": [
          {
            "glob": "packages/util/test/*.md",
            "input": "packages/util/test",
            "output": "."
          }
        ]
      },
      "dependsOn": ["^build-base"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../../coverage/packages/util/test"
      }
    }
  }
}
