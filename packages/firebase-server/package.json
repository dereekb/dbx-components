  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "peerDependencies": {
    "@dereekb/firebase": "12.7.0",
    "@dereekb/util": "12.7.0",
    "@dereekb/date": "12.7.0",
    "@dereekb/dbx-core": "12.7.0",
    "@dereekb/rxjs": "12.7.0",
    "express": "^5.0.0",
    "@dereekb/nestjs": "12.7.0",
