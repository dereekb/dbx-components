    "firebase-functions": "^7.0.0",
    "firebase-admin": "^13.0.0",
    "@nestjs/common": "^11.0.0",
    "make-error": "^1.3.0",
    "@google-cloud/firestore": "^8.0.0",
    "rxjs": "^7.8.0",
    "date-fns": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "class-validator": "^0.15.1",
