{
  "name": "@dereekb/firebase-server",
  "version": "12.7.0",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "main": "./src/index.js",
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./test": {
      "types": "./test/src/index.d.ts",
      "module": "./test/index.esm.js",
      "main": "./test/index.cjs.js",
      "node": {
        "require": "./test/index.cjs.js"
      },
      "browser": {
        "require": "./test/index.cjs.js",
        "import": "./test/index.esm.js"
      }
    },
    "./mailgun": {
      "types": "./mailgun/src/index.d.ts",
      "module": "./mailgun/index.esm.js",
      "main": "./mailgun/index.cjs.js",
      "node": {
        "require": "./mailgun/index.cjs.js"
      },
      "browser": {
        "require": "./mailgun/index.cjs.js",
        "import": "./mailgun/index.esm.js"
      }
    },
    "./zoho": {
      "types": "./zoho/src/index.d.ts",
      "module": "./zoho/index.esm.js",
      "main": "./zoho/index.cjs.js",
      "node": {
        "require": "./zoho/index.cjs.js"
      },
      "browser": {
        "require": "./zoho/index.cjs.js",
        "import": "./zoho/index.esm.js"
      }
    },
    "./model": {
      "types": "./model/src/index.d.ts",
      "module": "./model/index.esm.js",
      "main": "./model/index.cjs.js",
      "node": {
        "require": "./model/index.cjs.js"
      },
      "browser": {
        "require": "./model/index.cjs.js",
        "import": "./model/index.esm.js"
      }
    }
  },
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "peerDependencies": {
    "@dereekb/firebase": "*",
    "@dereekb/util": "*",
    "@dereekb/date": "*",
    "@dereekb/dbx-core": "*",
    "@dereekb/rxjs": "*",
    "express": "*",
    "@dereekb/nestjs": "*",
    "@dereekb/model": "*",
    "firebase-functions": "*",
    "firebase-admin": "*",
    "@nestjs/common": "*",
    "make-error": "*",
    "@google-cloud/firestore": "*",
    "rxjs": "*",
    "date-fns": "*",
    "@nestjs/core": "*",
    "@nestjs/platform-express": "*",
    "class-validator": "*",
    "ts-essentials": "*",
    "@google-cloud/storage": "*",
    "core-js": "*"
  },
  "dependencies": {}
}
