{
  "name": "firebase-server-test",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/firebase-server/test/src",
  "projectType": "library",
  "targets": {
    "build-base": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "importPath": "@dereekb/firebase-server/test",
        "outputPath": "dist/packages/firebase-server/test",
        "tsConfig": "packages/firebase-server/test/tsconfig.lib.json",
        "project": "packages/firebase-server/test/package.json",
        "main": "packages/firebase-server/test/src/index.ts",
        "format": ["esm", "cjs"],
        "generateExportsField": false,
        "external": "all",
        "assets": [],
        "compiler": "tsc"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "sourceMap": false,
          "extractLicenses": true
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./exec-with-emulator.sh 'npx nx run-tests firebase-server-test'"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "run-tests": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../../coverage/packages/firebase-server/test"
      }
    }
  }
}
