{
  "name": "firebase-server-test",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/firebase-server/test/src",
  "projectType": "library",
  "targets": {
    "build-base": {
      "dependsOn": []
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./exec-with-emulator.sh 'npx nx run-tests firebase-server-test'"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "run-tests": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../../coverage/packages/firebase-server/test"
      }
    }
  }
}
