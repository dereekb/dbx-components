{
  "name": "dbx-components-cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dbx-components-cli/src",
  "projectType": "library",
  "tags": ["scope:cli", "type:cli", "publishable"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/dbx-components-cli"],
      "options": {
        "command": "npx nx run dbx-components-cli:build-base",
        "color": true
      },
      "dependsOn": ["^build"]
    },
    "build-base": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/packages/dbx-components-cli",
        "main": "packages/dbx-components-cli/bin/dbx-components-cli.ts",
        "tsConfig": "packages/dbx-components-cli/tsconfig.lib.json",
        "format": ["esm"],
        "platform": "node",
        "target": "node20",
        "bundle": true,
        "thirdParty": false,
        "skipTypeCheck": true,
        "declaration": false,
        "esbuildOptions": {
          "banner": {
            "js": "#!/usr/bin/env node\nimport { createRequire as __createRequire } from 'node:module';\nconst require = __createRequire(import.meta.url);"
          }
        },
        "assets": [
          {
            "glob": "README.md",
            "input": "packages/dbx-components-cli",
            "output": "."
          },
          {
            "glob": "LICENSE",
            "input": ".",
            "output": "."
          }
        ]
      },
      "configurations": {
        "production": {
          "minify": false,
          "sourcemap": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "ci-publish-npmjs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd ./dist/packages/dbx-components-cli && npm publish --access public"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/dbx-components-cli"
      }
    }
  }
}
