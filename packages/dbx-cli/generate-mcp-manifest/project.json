{
  "name": "dbx-cli-generate-mcp-manifest",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dbx-cli/generate-mcp-manifest/src",
  "projectType": "application",
  "tags": [],
  "implicitDependencies": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/dbx-cli/generate-mcp-manifest"],
      "options": {
        "command": "npx nx run dbx-cli-generate-mcp-manifest:build-base",
        "color": true
      },
      "dependsOn": ["^build"]
    },
    "build-base": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{workspaceRoot}/dist/packages/dbx-cli/generate-mcp-manifest"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/packages/dbx-cli/generate-mcp-manifest",
        "main": "packages/dbx-cli/generate-mcp-manifest/src/generate-mcp-manifest/main.ts",
        "tsConfig": "packages/dbx-cli/generate-mcp-manifest/tsconfig.tool.json",
        "format": ["esm"],
        "platform": "node",
        "target": "node20",
        "bundle": true,
        "thirdParty": false,
        "skipTypeCheck": false,
        "declaration": false,
        "esbuildOptions": {
          "banner": {
            "js": "#!/usr/bin/env node\nimport { createRequire as __createRequire } from 'node:module';\nconst require = __createRequire(import.meta.url);"
          }
        }
      },
      "configurations": {
        "production": {
          "minify": false,
          "sourcemap": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../../coverage/packages/dbx-cli/generate-mcp-manifest"
      }
    }
  }
}
