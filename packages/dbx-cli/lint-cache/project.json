{
  "name": "dbx-cli-lint-cache",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dbx-cli/lint-cache/src",
  "projectType": "application",
  "tags": [],
  "implicitDependencies": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/dbx-cli/lint-cache"],
      "options": {
        "command": "npx nx run dbx-cli-lint-cache:build-base",
        "color": true
      },
      "dependsOn": ["^build"]
    },
    "build-base": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{workspaceRoot}/dist/packages/dbx-cli/lint-cache"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/packages/dbx-cli/lint-cache",
        "main": "packages/dbx-cli/lint-cache/src/main.ts",
        "tsConfig": "packages/dbx-cli/lint-cache/tsconfig.tool.json",
        "format": ["esm"],
        "platform": "node",
        "target": "node20",
        "bundle": true,
        "thirdParty": false,
        "skipTypeCheck": false,
        "declaration": false,
        "esbuildOptions": {
          "banner": {
            "js": "#!/usr/bin/env node\nimport { createRequire as __createRequire } from 'node:module';\nconst require = __createRequire(import.meta.url);"
          }
        }
      },
      "configurations": {
        "production": {
          "minify": false,
          "sourcemap": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
