{
  "name": "dbx-cli-model-test",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dbx-cli/model-test/src",
  "projectType": "library",
  "tags": ["publishable"],
  "targets": {
    "build-base": {
      "dependsOn": []
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../../coverage/packages/dbx-cli/model-test"
      }
    }
  }
}
