{
  "name": "dbx-cli-model-test",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dbx-cli/model-test/src",
  "projectType": "library",
  "tags": ["publishable"],
  "targets": {
    "build-base": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "importPath": "@dereekb/dbx-cli/model-test",
        "outputPath": "dist/packages/dbx-cli/model-test",
        "tsConfig": "packages/dbx-cli/model-test/tsconfig.lib.json",
        "project": "packages/dbx-cli/model-test/package.json",
        "main": "packages/dbx-cli/model-test/src/index.ts",
        "format": ["esm", "cjs"],
        "generateExportsField": true,
        "external": "all",
        "assets": [
          {
            "glob": "LICENSE",
            "input": ".",
            "output": "."
          }
        ],
        "rollupConfig": ["rollup.visualizer.config.ts"],
        "compiler": "swc"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "sourceMap": false,
          "extractLicenses": true
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../../coverage/packages/dbx-cli/model-test"
      }
    }
  }
}
