{
  "name": "dbx-cli-test",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dbx-cli/test/src",
  "projectType": "library",
  "targets": {
    "build-base": {
      "dependsOn": []
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "run-tests": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../../coverage/packages/dbx-cli/test"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nx run-tests dbx-cli-test"
      }
    }
  }
}
