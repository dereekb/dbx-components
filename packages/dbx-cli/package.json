{
  "name": "@dereekb/dbx-cli",
  "version": "13.13.0",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "dbx-cli-generate-firebase-api-manifest": "firebase-api-manifest/main.js",
    "dbx-cli-generate-firestore-indexes": "generate-firestore-indexes/main.js",
    "dbx-cli-generate-mcp-manifest": "generate-mcp-manifest/main.js",
    "dbx-cli-lint-cache": "lint-cache/main.js"
  },
  "exports": {
    "./firebase-api-manifest": {
      "default": "./firebase-api-manifest/main.js"
    },
    "./generate-firestore-indexes": {
      "default": "./generate-firestore-indexes/main.js"
    },
    "./generate-mcp-manifest": {
      "default": "./generate-mcp-manifest/main.js"
    },
    "./lint-cache": {
      "default": "./lint-cache/main.js"
    },
    "./manifest-extract": {
      "module": "./manifest-extract/index.esm.js",
      "types": "./manifest-extract/index.d.ts",
      "import": "./manifest-extract/index.cjs.mjs",
      "default": "./manifest-extract/index.cjs.js"
    },
    "./test": {
      "module": "./test/index.esm.js",
      "types": "./test/index.d.ts",
      "import": "./test/index.cjs.mjs",
      "default": "./test/index.cjs.js"
    }
  },
  "peerDependencies": {
    "@dereekb/date": "13.13.0",
    "@dereekb/firebase": "13.13.0",
    "@dereekb/model": "13.13.0",
    "@dereekb/nestjs": "13.13.0",
    "@dereekb/util": "13.13.0",
    "@nestjs/common": "^11.1.19",
    "arktype": "^2.2.0",
    "jiti": "2.6.1",
    "prettier": "3.8.3",
    "ts-morph": "^21.0.0",
    "vitest": "4.1.5",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@angular/core": "21.2.11",
    "@types/yargs": "^17.0.35",
    "eslint": "10.4.0"
  }
}
