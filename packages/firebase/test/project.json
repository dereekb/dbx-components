{
  "name": "firebase-test",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/firebase/test/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build-base": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "importPath": "@dereekb/firebase/test",
        "outputPath": "dist/packages/firebase/test",
        "tsConfig": "packages/firebase/test/tsconfig.lib.json",
        "project": "packages/firebase/test/package.json",
        "main": "packages/firebase/test/src/index.ts",
        "format": ["esm", "cjs"],
        "generateExportsField": false,
        "assets": [
          {
            "glob": "packages/firebase/test/*.md",
            "input": "packages/firebase/test",
            "output": "."
          }
        ]
      },
      "configurations": {
        "production": {
          "optimization": true,
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "vendorChunk": false
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./exec-with-emulator.sh 'npx nx run-tests firebase-test'"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "run-tests": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../../coverage/packages/firebase/test"
      }
    }
  }
}
