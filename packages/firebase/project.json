{
  "name": "firebase",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/firebase/src",
  "projectType": "library",
  "tags": ["publishable"],
  "implicitDependencies": ["!firebase-test", "!firebase-eslint", "util"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/firebase"],
      "inputs": ["production", "^production", "{workspaceRoot}/packages/firebase/eslint/**/*", "!{workspaceRoot}/packages/firebase/eslint/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)", "{workspaceRoot}/packages/firebase/test/**/*", "!{workspaceRoot}/packages/firebase/test/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)"],
      "options": {
        "commands": [
          {
            "command": "npx nx run firebase:build-base"
          },
          {
            "command": "npx nx run firebase-test:build-base"
          },
          {
            "command": "npx nx run firebase-eslint:build-base"
          }
        ],
        "parallel": false
      }
    },
    "build-base": {
      "dependsOn": []
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./exec-with-emulator.sh 'npx nx run-tests firebase --watch'"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./exec-with-emulator.sh 'npx nx run-tests firebase'"
      }
    },
    "run-all-tests": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "description": "run firebase tests. Should be called within a Firebase emulator environment",
            "command": "npx nx run-tests firebase"
          },
          {
            "description": "run firebase-test tests",
            "command": "npx nx run-tests firebase-test"
          }
        ],
        "color": true,
        "parallel": false
      }
    },
    "ci-publish-npmjs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd ./dist/packages/firebase && npm publish --access public"
      }
    },
    "run-tests": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/firebase"
      }
    }
  }
}
