{
  "name": "date",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/date/src",
  "projectType": "library",
  "tags": ["publishable"],
  "implicitDependencies": ["!util-test"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/date"],
      "options": {
        "command": "npx nx run date:build-base",
        "color": true
      }
    },
    "build-base": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "importPath": "@dereekb/date",
        "outputPath": "dist/packages/date",
        "main": "packages/date/src/index.ts",
        "tsConfig": "packages/date/tsconfig.lib.json",
        "compiler": "swc",
        "project": "packages/date/package.json",
        "format": ["esm", "cjs"],
        "generateExportsField": true,
        "assets": [
          {
            "glob": "packages/date/README.md",
            "input": ".",
            "output": "."
          },
          {
            "glob": "LICENSE",
            "input": ".",
            "output": "."
          }
        ],
        "rollupConfig": ["rollup.visualizer.config.ts"]
      },
      "configurations": {
        "production": {
          "optimization": true,
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "vendorChunk": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/date"
      }
    },
    "test-skip-build": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/packages/date", "{projectRoot}/.reports/vitest/*.date.junit.xml"],
      "cache": false
    },
    "test-timezones-usa": {
      "outputs": ["{workspaceRoot}/coverage/packages/date", "{projectRoot}/.reports/vitest/*.date.junit.xml"],
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "TZ=America/New_York && echo $TZ && TZ=$TZ nx test-skip-build date"
          },
          {
            "command": "TZ=America/Chicago && echo $TZ && TZ=$TZ nx test-skip-build date"
          },
          {
            "command": "TZ=America/Denver && echo $TZ && TZ=$TZ nx test-skip-build date"
          },
          {
            "command": "TZ=America/Los_Angeles && echo $TZ && TZ=$TZ nx test-skip-build date"
          },
          {
            "command": "TZ=America/Anchorage && echo $TZ && TZ=$TZ nx test-skip-build date"
          }
        ],
        "parallel": false
      }
    },
    "test-timezones-world": {
      "outputs": ["{workspaceRoot}/coverage/packages/date", "{projectRoot}/.reports/vitest/utc.date.junit.xml", "{projectRoot}/.reports/vitest/asia-tokyo.date.junit.xml", "{projectRoot}/.reports/vitest/asia-singapore.date.junit.xml", "{projectRoot}/.reports/vitest/europe-dublin.date.junit.xml", "{projectRoot}/.reports/vitest/pacific-auckland.date.junit.xml", "{projectRoot}/.reports/vitest/pacific-kiritimati.date.junit.xml", "{projectRoot}/.reports/vitest/pacific-niue.date.junit.xml"],
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "TZ=UTC && echo $TZ && TZ=$TZ nx test-skip-build date"
          },
          {
            "command": "TZ=Asia/Tokyo && echo $TZ && TZ=$TZ nx test-skip-build date"
          },
          {
            "command": "TZ=Asia/Singapore && echo $TZ && TZ=$TZ nx test-skip-build date"
          },
          {
            "command": "TZ=Europe/Dublin && echo $TZ && TZ=$TZ nx test-skip-build date"
          },
          {
            "command": "TZ=Pacific/Auckland && echo $TZ && TZ=$TZ nx test-skip-build date"
          },
          {
            "command": "TZ=Pacific/Kiritimati && echo $TZ && TZ=$TZ nx test-skip-build date"
          },
          {
            "command": "TZ=Pacific/Niue && echo $TZ && TZ=$TZ nx test-skip-build date"
          }
        ],
        "parallel": false
      }
    },
    "test-timezones-local": {
      "outputs": [
        "{workspaceRoot}/coverage/packages/date",
        "{projectRoot}/.reports/vitest/utc.date.junit.xml",
        "{projectRoot}/.reports/vitest/america-chicago.date.junit.xml",
        "{projectRoot}/.reports/vitest/pacific-auckland.date.junit.xml",
        "{projectRoot}/.reports/vitest/america-anchorage.date.junit.xml",
        "{projectRoot}/.reports/vitest/america-los_angeles.date.junit.xml",
        "{projectRoot}/.reports/vitest/america-new_york.date.junit.xml",
        "{projectRoot}/.reports/vitest/asia-tokyo.date.junit.xml",
        "{projectRoot}/.reports/vitest/asia-singapore.date.junit.xml",
        "{projectRoot}/.reports/vitest/europe-dublic.date.junit.xml"
      ],
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "TZ=Asia/Tokyo nx test-skip-build date"
          },
          {
            "command": "TZ=Asia/Singapore nx test-skip-build date"
          },
          {
            "command": "TZ=Europe/Dublin nx test-skip-build date"
          },
          {
            "command": "TZ=America/New_York nx test-skip-build date"
          },
          {
            "command": "TZ=America/Chicago nx test-skip-build date"
          },
          {
            "command": "TZ=America/Denver nx test-skip-build date"
          },
          {
            "command": "TZ=America/Los_Angeles nx test-skip-build date"
          },
          {
            "command": "TZ=America/Anchorage nx test-skip-build date"
          },
          {
            "command": "TZ=Pacific/Auckland nx test-skip-build date"
          },
          {
            "command": "TZ=Pacific/Kiritimati nx test-skip-build date"
          },
          {
            "command": "TZ=Pacific/Niue nx test-skip-build date"
          },
          {
            "command": "nx test-skip-build date"
          }
        ],
        "parallel": false
      }
    },
    "ci-publish-npmjs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd ./dist/packages/date && npm publish --access public"
      }
    }
  }
}
