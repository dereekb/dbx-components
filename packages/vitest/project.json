{
  "name": "vitest",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vitest/src",
  "projectType": "library",
  "tags": ["publishable"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/vitest",
        "main": "packages/vitest/src/index.ts",
        "tsConfig": "packages/vitest/tsconfig.lib.json",
        "assets": ["packages/vitest/*.md"]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "ci-publish-npmjs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd ./dist/packages/vitest && npm publish --access public"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/vitest"
      }
    }
  }
}
