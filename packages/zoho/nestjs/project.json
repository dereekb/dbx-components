{
  "name": "zoho-nestjs",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/zoho/nestjs/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build-base": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "importPath": "@dereekb/zoho/nestjs",
        "outputPath": "dist/packages/zoho/nestjs",
        "tsConfig": "packages/zoho/nestjs/tsconfig.lib.json",
        "project": "packages/zoho/nestjs/package.json",
        "main": "packages/zoho/nestjs/src/index.ts",
        "format": ["esm", "cjs"],
        "generateExportsField": true,
        "external": "all",
        "assets": [
          {
            "glob": "packages/zoho/nestjs/README.md",
            "input": ".",
            "output": "."
          },
          {
            "glob": "LICENSE",
            "input": ".",
            "output": "."
          },
          {
            "glob": "**/*.md",
            "input": "packages/zoho/nestjs/docs",
            "output": "docs"
          }
        ],
        "rollupConfig": ["rollup.visualizer.config.ts"],
        "compiler": "tsc"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "sourceMap": false,
          "extractLicenses": true
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../../coverage/packages/zoho/nestjs"
      }
    }
  }
}
