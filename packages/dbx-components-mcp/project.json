{
  "name": "dbx-components-mcp",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/dbx-components-mcp/src",
  "projectType": "library",
  "tags": ["scope:mcp", "type:server", "publishable"],
  "targets": {
    "generate-firebase-models": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/generated/firebase-models.generated.ts"],
      "inputs": ["{projectRoot}/scripts/extract-firebase-models.mjs", "{workspaceRoot}/packages/firebase/src/lib/model/**/*.ts"],
      "options": {
        "command": "node packages/dbx-components-mcp/scripts/extract-firebase-models.mjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "generate-rule-catalog": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/generated/rule-catalog.generated.json", "{projectRoot}/generated/rule-catalog.generated.ts"],
      "inputs": ["{projectRoot}/scripts/extract-rule-catalog.mjs", "{projectRoot}/src/tools/*/codes.ts"],
      "options": {
        "command": "node packages/dbx-components-mcp/scripts/extract-rule-catalog.mjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "generate-manifests": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/generated/dereekb-util.semantic-types.mcp.generated.json",
        "{projectRoot}/generated/dereekb-model.semantic-types.mcp.generated.json",
        "{projectRoot}/generated/dereekb-date.semantic-types.mcp.generated.json",
        "{projectRoot}/generated/dereekb-firebase.semantic-types.mcp.generated.json",
        "{projectRoot}/generated/dereekb-firebase-server.semantic-types.mcp.generated.json",
        "{projectRoot}/generated/dereekb-dbx-web.ui-components.mcp.generated.json",
        "{projectRoot}/generated/dereekb-dbx-form.forge-fields.mcp.generated.json",
        "{projectRoot}/generated/dereekb-dbx-core.pipes.mcp.generated.json",
        "{projectRoot}/generated/dereekb-dbx-core.actions.mcp.generated.json",
        "{projectRoot}/generated/dereekb-dbx-core.filters.mcp.generated.json"
      ],
      "inputs": [
        "{projectRoot}/scripts/generate-manifests.mjs",
        "{projectRoot}/src/scan/**/*.ts",
        "{projectRoot}/src/manifest/**/*.ts",
        "{workspaceRoot}/packages/util/dbx-mcp.scan.json",
        "{workspaceRoot}/packages/util/src/**/*.ts",
        "{workspaceRoot}/packages/model/dbx-mcp.scan.json",
        "{workspaceRoot}/packages/model/src/**/*.ts",
        "{workspaceRoot}/packages/date/dbx-mcp.scan.json",
        "{workspaceRoot}/packages/date/src/**/*.ts",
        "{workspaceRoot}/packages/firebase/dbx-mcp.scan.json",
        "{workspaceRoot}/packages/firebase/src/**/*.ts",
        "{workspaceRoot}/packages/firebase-server/dbx-mcp.scan.json",
        "{workspaceRoot}/packages/firebase-server/src/**/*.ts",
        "{workspaceRoot}/packages/firebase-server/test/src/**/*.ts",
        "{workspaceRoot}/packages/dbx-web/dbx-mcp.scan.json",
        "{workspaceRoot}/packages/dbx-web/src/**/*.ts",
        "{workspaceRoot}/packages/dbx-form/dbx-mcp.scan.json",
        "{workspaceRoot}/packages/dbx-form/src/**/*.ts",
        "{workspaceRoot}/packages/dbx-core/dbx-mcp.scan.json",
        "{workspaceRoot}/packages/dbx-core/src/lib/pipe/**/*.ts",
        "{workspaceRoot}/packages/dbx-core/src/lib/action/**/*.ts",
        "{workspaceRoot}/packages/dbx-core/src/lib/filter/**/*.ts"
      ],
      "options": {
        "command": "node packages/dbx-components-mcp/scripts/generate-manifests.mjs",
        "cwd": "{workspaceRoot}"
      }
    },
    "regenerate": {
      "executor": "nx:run-commands",
      "dependsOn": ["generate-firebase-models", "generate-manifests", "generate-rule-catalog"],
      "options": {
        "command": "echo \"dbx-components-mcp regeneration complete\""
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/dbx-components-mcp"],
      "options": {
        "command": "npx nx run dbx-components-mcp:build-base",
        "color": true
      },
      "dependsOn": ["^build"]
    },
    "build-base": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "dependsOn": ["generate-firebase-models", "generate-manifests", "generate-rule-catalog"],
      "options": {
        "outputPath": "dist/packages/dbx-components-mcp",
        "main": "packages/dbx-components-mcp/bin/dbx-components-mcp.ts",
        "tsConfig": "packages/dbx-components-mcp/tsconfig.lib.json",
        "format": ["esm"],
        "platform": "node",
        "target": "node20",
        "bundle": true,
        "thirdParty": false,
        "skipTypeCheck": true,
        "declaration": false,
        "esbuildOptions": {
          "banner": {
            "js": "#!/usr/bin/env node\nimport { createRequire as __createRequire } from 'node:module';\nconst require = __createRequire(import.meta.url);"
          }
        },
        "assets": [
          {
            "glob": "README.md",
            "input": "packages/dbx-components-mcp",
            "output": "."
          },
          {
            "glob": "LICENSE",
            "input": ".",
            "output": "."
          },
          {
            "glob": "generated/*.json",
            "input": "packages/dbx-components-mcp",
            "output": "."
          }
        ]
      },
      "configurations": {
        "production": {
          "minify": false,
          "sourcemap": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "ci-publish-npmjs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd ./dist/packages/dbx-components-mcp && npm publish --access public"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/packages/dbx-components-mcp"
      }
    }
  }
}
