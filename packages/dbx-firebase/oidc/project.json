{
  "name": "dbx-firebase-oidc",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/dbx-firebase/oidc/src",
  "prefix": "dbx",
  "tags": [],
  "targets": {
    "build-base": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/packages/dbx-firebase/oidc"],
      "options": {
        "project": "packages/dbx-firebase/oidc/ng-package.json",
        "tsConfig": "packages/dbx-firebase/oidc/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "packages/dbx-firebase/oidc/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production",
      "dependsOn": []
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../../coverage/packages/dbx-firebase/oidc"
      }
    }
  }
}
