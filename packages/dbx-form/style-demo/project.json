{
  "name": "dbx-form-style-demo",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/dbx-form/style-demo/src",
  "prefix": "dbx",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/dbx-form/style-demo"],
      "options": {
        "commands": [
          {
            "description": "build dbx-form-style-demo production",
            "command": "npx nx run dbx-form-style-demo:build-base:production"
          }
        ],
        "parallel": false,
        "color": true
      }
    },
    "build-base": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/packages/dbx-form/style-demo"],
      "options": {
        "project": "packages/dbx-form/style-demo/ng-package.json",
        "tsConfig": "packages/dbx-form/style-demo/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "packages/dbx-form/style-demo/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production",
      "dependsOn": []
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../../coverage/packages/dbx-form/style-demo"
      }
    }
  }
}
