{
  "name": "workspace",
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "prefix": "workspace",
  "targets": {
    "build-all": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx nx run-many -t build --all --parallel=2",
        "color": true
      }
    },
    "lint-fix-all": {
      "executor": "nx:run-commands",
      "dependsOn": [],
      "options": {
        "description": "",
        "command": "npx nx run-many --tui=false --parallel=6 --exclude=workspace,util-test,firebase-test,firebase-server-test --target=lint --fix"
      }
    },
    "start-release": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./start-release.sh"
      }
    },
    "prettier": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./start-release.sh"
      }
    },
    "release-dry-run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/release.mjs --dry-run=true --skip-publish --verbose"
      }
    },
    "release": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/release.mjs --dry-run=false --skip-publish --verbose"
      }
    },
    "deploy-firebase-rules": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx firebase --project=default deploy --only firestore:rules,storage"
      }
    },
    "ci-deploy-firebase-rules": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx firebase --project=default deploy --only firestore:rules,storage"
      }
    },
    "update-peer-deps": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "node tools/scripts/update-peer-deps-from-imports.mjs"
      }
    },
    "update-peer-deps-dry-run": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "node tools/scripts/update-peer-deps-from-imports.mjs --dry-run"
      }
    }
  }
}
