{
  "name": "workspace",
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "prefix": "workspace",
  "targets": {
    "build-all": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [{ "command": "npx nx build util" }, { "command": "npx nx run-many -t build --projects=rxjs,model,date" }, { "command": "npx nx build firebase" }, { "command": "npx nx build firebase-server" }, { "command": "npx nx run-many -t build --all" }],
        "parallel": false,
        "color": true
      }
    },
    "lint-all": {
      "executor": "nx:run-commands",
      "dependsOn": [],
      "options": {
        "description": "",
        "command": "npx nx run-many --tui=false --parallel=6 --exclude=workspace,util-test,firebase-test,firebase-server-test --target=lint"
      }
    },
    "lint-fix-all": {
      "executor": "nx:run-commands",
      "dependsOn": [],
      "options": {
        "description": "",
        "command": "npx nx run-many --tui=false --parallel=6 --exclude=workspace,util-test,firebase-test,firebase-server-test --target=lint --fix"
      }
    },
    "start-release": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./start-release.sh"
      }
    },
    "prettier": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./start-release.sh"
      }
    },
    "release-dry-run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/release.mjs --dry-run=true --skip-publish --verbose"
      }
    },
    "release": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/release.mjs --dry-run=false --skip-publish --verbose"
      }
    },
    "deploy-firebase-rules": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx firebase --project=default deploy --only firestore:rules,storage"
      }
    },
    "ci-deploy-firebase-rules": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx firebase --project=default deploy --only firestore:rules,storage"
      }
    },
    "ci-test-firebase-all": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [{ "command": "npx nx run-all-tests firebase" }, { "command": "npx nx run-all-tests firebase-server" }, { "command": "npx nx run-tests dbx-firebase" }, { "command": "npx nx run-tests demo-api" }],
        "parallel": false
      }
    },
    "ci-test-firebase-all-with-emulators": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx firebase --project=default emulators:exec --only auth,firestore,storage 'npx nx run workspace:ci-test-firebase-all'"
      }
    },
    "ci-publish-npmjs-all": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          { "command": "npx nx run vitest:ci-publish-npmjs && npx nx run util:ci-publish-npmjs && npx nx run rxjs:ci-publish-npmjs" },
          { "command": "npx nx run date:ci-publish-npmjs && npx nx run model:ci-publish-npmjs && npx nx run browser:ci-publish-npmjs" },
          { "command": "npx nx run nestjs:ci-publish-npmjs && npx nx run firebase:ci-publish-npmjs && npx nx run firebase-server:ci-publish-npmjs" },
          { "command": "npx nx run analytics:ci-publish-npmjs && npx nx run zoho:ci-publish-npmjs && npx nx run zoom:ci-publish-npmjs && npx nx run calcom:ci-publish-npmjs" },
          { "command": "npx nx run dbx-core:ci-publish-npmjs && npx nx run dbx-web:ci-publish-npmjs && npx nx run dbx-analytics:ci-publish-npmjs && npx nx run dbx-form:ci-publish-npmjs" },
          { "command": "npx nx run dbx-firebase:ci-publish-npmjs" }
        ],
        "parallel": false
      }
    },
    "update-peer-deps": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "node tools/scripts/update-peer-deps-from-imports.mjs"
      }
    },
    "update-peer-deps-dry-run": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "node tools/scripts/update-peer-deps-from-imports.mjs --dry-run"
      }
    }
  }
}
