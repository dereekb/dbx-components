rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // MARK: Utilities
    function userClaimsIsSysAdmin() {
      return request.auth.token.keys().hasAll(["a"]) && request.auth.token.a == 1;
    }

    // MARK: Uploads under User
    match /uploads/u/{uid} {
      allow read: if isUploadUser() || userClaimsIsSysAdmin();

      // MARK: Test File
      // Mirrors STORAGE_FILE_PURPOSE_UPLOAD_POLICIES[USER_TEST_FILE_PURPOSE].
      match /test/{filename=**} {
        allow write: if (isUploadUser() && isAllowedTestFile()) || userClaimsIsSysAdmin();
      }

      // MARK: Log File
      // Mirrors STORAGE_FILE_PURPOSE_UPLOAD_POLICIES[USER_LOG_FILE_PURPOSE].
      match /log/{filename=**} {
        allow write: if (isUploadUser() && isAllowedLogFile()) || userClaimsIsSysAdmin();
      }

      // MARK: Avatar
      // Mirrors STORAGE_FILE_PURPOSE_UPLOAD_POLICIES[USER_AVATAR_PURPOSE].
      match /avatar.img {
        allow write: if isUploadUser() || userClaimsIsSysAdmin() && isAllowedAvatarSize();
      }

      function isUploadUser() {
        return request.auth.uid == uid;
      }

      function isAllowedAvatarSize() {
        // max 2mb image (client-side compression downsizes before upload)
        return request.resource.size < 2 * 1024 * 1024 && request.resource.contentType.matches('image/.*')
      }

      function isAllowedTestFile() {
        // max 8mb; text/plain or image/jpeg or image/png
        return request.resource.size < 8 * 1024 * 1024 && (
          request.resource.contentType == 'text/plain'
            || request.resource.contentType == 'image/jpeg'
            || request.resource.contentType == 'image/png'
        )
      }

      function isAllowedLogFile() {
        // max 2mb; text/plain only
        return request.resource.size < 2 * 1024 * 1024 && request.resource.contentType == 'text/plain'
      }
    }

    // MARK: User Files
    match /u/{uid} {
      allow read: if isUser() || userClaimsIsSysAdmin();  // anyone can read anyone else's files

      match /test {
        allow read: if false;  // can only be read by the user
      }

      match /avatar {
        allow read: if true;  // anyone can read anyone else's avatar
      }

      function isUser() {
        return request.auth.uid == uid;
      }
    }

    match /{allPaths=**} {
      allow read, write: if false;
      allow list: if false; // not allowed to list anywhere
    }

  }

}
