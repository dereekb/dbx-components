// MARK: Dependency Module — token cache (memory → file → Firestore)
export const __APP_CAMEL__ZohoAccessTokenCacheFactory = (collections: __APP_PASCAL__FirestoreCollections) => {
  const memoryCache = memoryZohoAccountsAccessTokenCacheService();
  const fileCache = fileZohoAccountsAccessTokenCacheService();
  const firebaseCache = firebaseZohoAccountsAccessTokenCacheService(collections.systemStateCollection);
  return mergeZohoAccountsAccessTokenCacheServices([memoryCache, fileCache, firebaseCache]);
};

@Module({
  imports: [__APP_PASCAL__ApiFirestoreModule],
  providers: [
